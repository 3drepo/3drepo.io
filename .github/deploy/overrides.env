# Per-branch deploy overrides for .github/workflows/buildAndDeploy.yml.
#
# Why this file exists:
#   The deploy workflow is driven by `repository_dispatch`, which always runs
#   the workflow DEFINITION from the default branch (master). That means edits
#   to buildAndDeploy.yml on a feature branch are ignored for /deploy runs.
#   To still allow per-branch tuning (the equivalent of the old Azure
#   `customHelmOverride`), the deploy job checks out the PR head and sources
#   THIS file, so the values below are read from whichever branch is deployed.
#
# How to use:
#   Edit these on your branch to deploy with a different chart version or extra
#   Helm overrides. Changes show up in the PR diff and are therefore reviewable.
#
# HELM_CHART_VERSION  - version of the oci://.../helm/io chart to deploy.
# CUSTOM_HELM_OVERRIDE - extra comma-delimited `helm --set` overrides. Prefix
#   IO application settings with `config.`; omit it to change chart values.
#   e.g. CUSTOM_HELM_OVERRIDE=config.APP_QUEUE_DNS=issue-xxx-rabbitmq,config.ADDITIONAL_CONFIG=hello

HELM_CHART_VERSION=5.23.0
CUSTOM_HELM_OVERRIDE=config.ADDITIONAL_CONFIG=hello
